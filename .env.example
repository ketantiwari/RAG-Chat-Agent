# ==============================================================================
# RAG Chat Agent Environment Configuration Template
# ==============================================================================
# Copy this file to .env and fill in your keys before starting the applications.
# Example: cp .env.example .env

# ------------------------------------------------------------------------------
# API Keys (Required for LLM and Search Services)
# ------------------------------------------------------------------------------
# Google Gemini API Key (Obtain from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API Key (Obtain from Groq Console)
GROQ_API_KEY=your_groq_api_key_here

# Tavily API Key (Obtain from Tavily.com for web search grounding)
TAVILY_API_KEY=your_tavily_api_key_here

# ------------------------------------------------------------------------------
# Application Defaults
# ------------------------------------------------------------------------------
# Primary LLM provider to use (options: gemini, groq)
LLM_PROVIDER=gemini

# Specific model variations
GEMINI_MODEL=gemini-1.5-flash
GROQ_MODEL=llama-3.3-70b-versatile

# Text embedding model (SentenceTransformers model name)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Log level (options: DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ------------------------------------------------------------------------------
# Container Configurations (Optional)
# ------------------------------------------------------------------------------
# Backend API Base URL (used by the Streamlit frontend to reach the FastAPI server)
# API_BASE=http://localhost:8000/api
